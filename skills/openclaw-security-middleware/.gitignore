# Ignore Node.js logs and modules (in case users add any accidentally)
node_modules/
npm-debug.log
yarn-error.log
yarn-debug.log

# Ignore runtime generated audit and error logs
logs/audit*.log
logs/error.log
logs/rate_limit_*.json
logs/rate_limit_*.lock

# Allow the logs directory to be checked in, but keep it empty
!logs/.gitkeep

# macOS specific
.DS_Store
